<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Write generated files to disk so the [ModuleInitializer] bootstrap is visible -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>obj\Generated</CompilerGeneratedFilesOutputPath>
    <FoundryDiagnostics>true</FoundryDiagnostics>
    <!-- Output diagnostics to the exe entry point's bin folder, not this library's bin -->
    <FoundryDiagnosticsPath>$(MSBuildProjectDirectory)\..\GroupChatAgentFrameworkApp\bin\$(Configuration)\$(TargetFramework)\FoundryDiagnostics</FoundryDiagnosticsPath>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\NexusLabs.Foundry.MicrosoftAgentFramework\NexusLabs.Foundry.MicrosoftAgentFramework.csproj" />
    <ProjectReference Include="..\..\..\NexusLabs.Foundry.MicrosoftAgentFramework.Workflows\NexusLabs.Foundry.MicrosoftAgentFramework.Workflows.csproj" />
    <ProjectReference Include="..\..\..\NexusLabs.Foundry.MicrosoftAgentFramework.Generators\NexusLabs.Foundry.MicrosoftAgentFramework.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <Import Project="..\..\..\NexusLabs.Foundry.MicrosoftAgentFramework.Generators\build\NexusLabs.Foundry.MicrosoftAgentFramework.Generators.props" />
  <Import Project="..\..\..\NexusLabs.Foundry.MicrosoftAgentFramework.Generators\build\NexusLabs.Foundry.MicrosoftAgentFramework.Generators.targets" />

  <Import Project="..\..\Needlr.Generators.props" />

</Project>
